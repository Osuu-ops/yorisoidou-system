name: Chat Packet Guard





on:


  pull_request:


    paths:


      - "START_HERE.md"


      - "docs/MEP/**"


      - ".github/workflows/chat_packet_guard.yml"


      - ".github/workflows/chat_packet_update_dispatch.yml"


  workflow_dispatch:





permissions:


  contents: read





jobs:


  guard:


    runs-on: ubuntu-latest


    steps:


      - name: Checkout


        uses: actions/checkout@v4


        with:


          fetch-depth: 0





      - name: Require files


        shell: bash


        run: |


          set -euo pipefail


          test -f docs/MEP/CHAT_PACKET.md


          test -f docs/MEP/MEP_MANIFEST.yml


          test -f START_HERE.md


          test -f docs/MEP/build_chat_packet.py





      - name: Regenerate and ensure no diff


        shell: bash


        run: |


          set -euo pipefail


          python3 docs/MEP/build_chat_packet.py


          if ! git diff --exit-code -- docs/MEP/CHAT_PACKET.md; then


            echo "::error file=docs/MEP/CHAT_PACKET.md::CHAT_PACKET.md is outdated. Run Chat Packet Update (Dispatch) or regenerate and commit."


            exit 1


          fi



      # --- Debug artifact capture (injected by automation) ---
      - name: Prepare debug artifact
        if: always()
        run: |
          mkdir -p debug_artifact
          tar -czf debug_artifact/workspace_${{ github.run_id }}.tar.gz --exclude='.git' --exclude='node_modules' --exclude='**/cache' .
          printf "Collected files:\n" > debug_artifact/collected.txt
          tar -tf debug_artifact/workspace_${{ github.run_id }}.tar.gz >> debug_artifact/collected.txt || true

      - name: Upload debug artifact
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: debug-workspace-${{ github.run_id }}
          path: debug_artifact
